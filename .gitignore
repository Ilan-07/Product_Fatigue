# Environment files
.env
.env.local
.env.*.local

# Data (large files — tracked via DVC). Keep dir placeholders.
data/raw/*
data/processed/*
data/intermediate/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/intermediate/.gitkeep

# Trained models (regenerated by pipeline). Keep dir placeholder.
models/*
!models/.gitkeep

# Generated pipeline outputs (curated subset lives in docs/figures/). Keep dir placeholder.
outputs/*
!outputs/.gitkeep

# Release-only assets (PDFs etc. attached to GitHub Releases)
release_assets/

# Root-level PDFs
*.pdf
!docs/**/*.pdf

# Node / Frontend
node_modules/
frontend/dist/
frontend/.vite/
frontend/coverage/

# MLflow / Experiment tracking
mlruns/
mlflow.db
*.db

# OS files
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Jupyter checkpoints
.ipynb_checkpoints/
*-checkpoint.ipynb
