# Copy to .env and fill in. Never commit .env.

# --- API ---
# Where the FastAPI server binds when run outside docker
API_HOST=0.0.0.0
API_PORT=8000

# --- MLflow ---
# Tracking URI for experiment logs. Docker compose default below.
MLFLOW_TRACKING_URI=http://localhost:5001

# --- Grafana ---
# Override the default admin password in docker/docker-compose.yml
GF_SECURITY_ADMIN_PASSWORD=change-me

# --- Frontend (Vite) ---
# Vite only exposes vars prefixed with VITE_ to the browser bundle.
# Leave unset to use the dev proxy (http://localhost:8000) configured in vite.config.ts.
# VITE_API_BASE=http://localhost:8000
